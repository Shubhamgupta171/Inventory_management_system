# =========================================================================== #
# Root environment file for docker-compose.
# Copy to `.env` (which is git-ignored) and change the password before use.
#   cp .env.example .env
# =========================================================================== #

# --- PostgreSQL ---
POSTGRES_USER=ioms_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=inventory
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8000
# Comma-separated allowed origins, or "*". For local compose, "*" is fine.
CORS_ORIGINS=*
LOW_STOCK_THRESHOLD=10
SEED_DATA=true
ENVIRONMENT=development

# --- Frontend ---
FRONTEND_PORT=3000
# URL the browser uses to reach the backend (build-time for Vite).
VITE_API_URL=http://localhost:8000
