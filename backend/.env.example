# ---- Backend configuration (copy to .env and adjust) ----

# SQLAlchemy database URL. For local docker-compose this is injected
# automatically; set it explicitly when deploying.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/inventory

# Comma-separated allowed origins for CORS, or "*" for all.
# In production set this to your deployed frontend URL, e.g.
# CORS_ORIGINS=https://your-frontend.vercel.app
CORS_ORIGINS=*

# Products at or below this stock level are flagged as "low stock".
LOW_STOCK_THRESHOLD=10

# Seed sample products/customers on first boot (only if tables are empty).
SEED_DATA=true

ENVIRONMENT=development
